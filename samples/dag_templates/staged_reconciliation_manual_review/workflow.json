      "configuration": {
        "schema_version": "2b.1",
        "id": "22000000-0000-4000-8000-000000000002",
        "version": 1,
        "project_id": "20000000-0000-4000-8000-000000000002",
        "display_name": "Vendor Invoice Reconciliation",
        "left_dataset_id": "21000000-0000-4000-8000-000000000003",
